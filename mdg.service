[Unit]
Description=MDG FastAPI (gunicorn)
After=network.target

[Service]
User=mdg
Group=mdg
WorkingDirectory=/opt/mdg
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/mdg/venv/bin/gunicorn -c /opt/mdg/gunicorn.conf.py app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
