<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Beverage — Data Generator</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    :root{
      --brand:#0078D4; --brandHover:#106EBE; --brandPressed:#005A9E;
      --bg:#F5F5F6; --card:#FFFFFF; --stroke:#E1E1E6; --strokeStrong:#C7C7CC;
      --fg:#242424; --fg2:#4A4A4A; --fg3:#6B6B6B;
      --success:#107C10; --error:#D13438; --warn:#8B6100; --warnBg:#FFFBEA; --warnBr:#FFE58F;
      --radius:12px; --shadow:0 1px 2px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.06);
    }
    html,body{height:100%;background:var(--bg);color:var(--fg);
      font-family:Segoe UI,"Segoe UI Variable Text",system-ui,-apple-system,Roboto,Arial;}
    h1,h2,h3{margin:0 0 .5rem 0;font-weight:600}
    h3{font-size:1rem;color:var(--fg2)}
    .appbar{position:sticky;top:0;background:#fff;border-bottom:1px solid var(--stroke);
      padding:16px 24px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow)}
    .logo{width:28px;height:28px;border-radius:6px;background:var(--brand)}
    .container{max-width:1400px;margin:0 auto;padding:18px}
    .row{display:flex;gap:12px;flex-wrap:wrap;align-items:stretch}
    .card{background:var(--card);border:1px solid var(--stroke);border-radius:var(--radius);box-shadow:var(--shadow);padding:12px;flex:1;min-width:300px}
    .muted{color:var(--fg3)} .hr{height:1px;background:var(--stroke);margin:12px 0}
    button,input,select{font:inherit;color:inherit}
    button{background:var(--brand);color:#fff;border:none;padding:8px 12px;border-radius:8px;cursor:pointer;transition:background .15s,transform .02s}
    button:hover{background:var(--brandHover)} button:active{background:var(--brandPressed);transform:translateY(1px)}
    button.secondary{background:#fff;color:var(--fg);border:1px solid var(--stroke)}
    button.secondary:hover{border-color:var(--strokeStrong);box-shadow:var(--shadow)}
    a.btn{display:inline-block;text-decoration:none}
    label{display:block;font-size:.8rem;color:var(--fg3);margin:8px 0 4px}
    input[type="number"],input[type="text"],input[type="url"],input[type="password"],select{
      width:100%;background:#fff;color:var(--fg);border:1px solid var(--stroke);border-radius:8px;padding:8px 10px;outline:none}
    input:focus,select:focus{border-color:var(--brand);box-shadow:0 0 0 2px #D6EBFF}
    input[type="range"]{width:100%;accent-color:var(--brand)}
    table{width:100%;border-collapse:collapse;margin-top:8px}
    thead th{text-align:left;font-weight:600;font-size:.85rem;border-bottom:1px solid var(--strokeStrong);padding:10px 8px;background:#FAFAFB}
    tbody td{border-bottom:1px solid var(--stroke);padding:10px 8px;font-size:.9rem}
    tbody tr:hover{background:#FAFAFF}
    code{background:#F2F7FD;color:#0F2E5D;padding:2px 6px;border-radius:6px;border:1px solid #E2EEF9;font-family:ui-monospace,Menlo,Consolas,monospace;font-size:.85em}
    .infobar{display:flex;align-items:center;gap:8px;border:1px solid var(--stroke);background:#fff;padding:10px 12px;border-radius:8px;box-shadow:var(--shadow)}
    .toast{margin-top:8px;font-size:.9rem}.toast.ok{color:var(--success)}.toast.err{color:var(--error)}
    .status-chip{display:inline-flex;align-items:center;gap:6px;padding:3px 8px;border-radius:999px;font-size:.8rem;border:1px solid var(--stroke);background:#fff}
    .status-dot{width:8px;height:8px;border-radius:50%;background:var(--fg3)} .status-dot.ok{background:var(--success)} .status-dot.err{background:var(--error)}
    .chart-wrap{background:#fff;border:1px solid var(--stroke);border-radius:var(--radius);padding:12px;box-shadow:var(--shadow)}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px}
    .errorbox{display:none;background:#FFF5F5;border:1px solid #F4CCCC;color:#7A0000;border-radius:8px;padding:10px;white-space:pre-wrap;word-break:break-word}
    .errorbox.show{display:block}
    .curlbox{display:none;background:var(--warnBg);border:1px solid var(--warnBr);color:var(--warn);border-radius:8px;padding:10px}
    .curlbox.show{display:block}
    .curl-actions{display:flex;gap:8px;align-items:center;justify-content:space-between;margin-bottom:8px}
    .curl-actions .title{font-weight:600}
    .kbd{padding:2px 6px;border:1px solid #ddd;border-bottom-width:2px;border-radius:6px;background:#fff;font-family:ui-monospace,Menlo,Consolas,monospace}
  </style>
</head>
<body>
  <div class="appbar">
    <span class="logo" aria-hidden="true"></span>
    <div style="font-size:1.05rem;font-weight:600">Beverage — Data Generator</div>
    <div class="muted" style="margin-left:auto"><a class="btn secondary" href="/ui" style="padding:6px 10px">Back to Main</a></div>
  </div>

  <div class="container">
    <div id="persistInfo" class="muted" style="margin-bottom:12px"></div>

    <div class="row">
      <div class="card" style="max-width:520px">
        <h3>Run</h3>
        <div class="infobar" id="statusBox">Status: …</div>
        <div class="hr"></div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px">
          <div>
            <label for="interval">Interval (seconds)</label>
            <input id="interval" type="number" min="1" step="1"/>
          </div>
          <div>
            <label for="batch">Batch size</label>
            <input id="batch" type="number" min="1" max="100" step="1"/>
          </div>
        </div>

        <div class="inline" style="margin-top:10px;gap:8px;flex-wrap:wrap">
          <button id="startBtn">Start</button>
          <button id="stopBtn" class="secondary">Stop</button>
          <button id="generateNowBtn" class="secondary">Generate now</button>
          <button id="saveCore" class="secondary">Save run</button>
          <button id="makeActive" class="secondary" title="Switch generator domain to Beverage">Make Beverage Active</button>
        </div>
        <div id="toastCore" class="toast"></div>
      </div>

      <div class="card" style="max-width:560px">
        <h3>CluedIn Sink</h3>
        <label><input type="checkbox" id="send_enabled"/> Enable sending</label>
        <label for="cluedin_endpoint">Endpoint URL</label>
        <input id="cluedin_endpoint" type="url" placeholder="https://host/api/ingest/beverage"/>
        <label for="bearer_token">Bearer token</label>
        <input id="bearer_token" type="password" placeholder="••••••"/>
        <label for="send_mode">Send mode</label>
        <select id="send_mode">
          <option value="record">Per record</option>
          <option value="batch">Batch (JSON array)</option>
        </select>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px">
          <div>
            <label for="timeout_seconds">Timeout (s)</label>
            <input id="timeout_seconds" type="number" min="1" step="0.5"/>
          </div>
          <div>
            <label for="max_retries">Max retries</label>
            <input id="max_retries" type="number" min="0" step="1"/>
          </div>
        </div>
        <button id="saveSink" style="margin-top:10px">Save sink config</button>
        <div id="toastSink" class="toast"></div>

        <div style="display:flex;align-items:center;gap:8px;margin-top:8px;">
          <div id="sendStatus" class="status-chip"><span class="status-dot"></span><span>Send status: —</span></div>
        </div>

        <!-- Error details -->
        <div id="sendErrorBox" class="errorbox" style="margin-top:8px;"></div>

        <!-- cURL helper -->
        <div id="sendCurlWrap" class="curlbox" style="margin-top:8px;">
          <div class="curl-actions">
            <div class="title">Test with cURL</div>
            <div>
              <button id="copyCurlBtn" class="secondary">Copy</button>
            </div>
          </div>
          <pre id="sendCurlText" style="white-space:pre-wrap;word-break:break-word;margin:0"></pre>
          <div class="muted" style="margin-top:6px">
            Tip: Paste into a terminal. On Windows PowerShell, run via <span class="kbd">cmd /c</span> or adapt quotes.
          </div>
        </div>

        <div style="margin-top:10px;">
          <label>Last row (sanitized) recently generated</label>
          <div id="lastSentBox" style="white-space:pre;overflow:auto;max-height:180px;border:1px solid var(--stroke);border-radius:8px;padding:10px;background:#FAFAFB;"></div>
        </div>
      </div>
    </div>

    <div class="row" style="margin-top:12px">
      <div class="card">
        <h3>Beverage Scenarios</h3>
        <div class="muted" style="margin-bottom:6px">Adjust probabilities (0.0–1.0) and save.</div>
        <div id="scenarios_beverage" class="grid"></div>
        <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
          <button id="saveScenarios">Save scenarios</button>
          <button id="pullScenarios" class="secondary">Reload from server</button>
        </div>
        <div id="toastScenarios" class="toast"></div>
      </div>
    </div>

    <div class="row" style="margin-top:12px">
      <div class="card" style="flex:2">
        <h3>Live (Beverage-only)</h3>
        <div id="streamStatus" class="muted">Connecting…</div>
        <table>
          <thead>
            <tr>
              <th style="width:160px">Timestamp</th>
              <th>Record ID</th>
              <th>Text (technical)</th>
              <th>Issues</th>
            </tr>
          </thead>
          <tbody id="rows"></tbody>
        </table>
      </div>

      <div class="card" style="flex:1">
        <div class="chart-wrap">
          <h3>Badness — Recent % Bad</h3>
          <canvas id="badnessLine" height="180" aria-label="Recent badness line chart"></canvas>
          <div class="muted" style="font-size:.85rem;margin-top:6px;">Share of recent records with ≥1 issue (sliding window).</div>
        </div>
        <div class="chart-wrap" style="margin-top:12px;">
          <h3>Top Issue Types</h3>
          <canvas id="issuesBar" height="200" aria-label="Top issues bar chart"></canvas>
          <div class="muted" style="font-size:.85rem;margin-top:6px;">Counts per issue (top 12).</div>
        </div>
      </div>
    </div>

    <div class="row" style="margin-top:12px">
      <div class="card" style="max-width:560px">
        <h3>Export (download JSON)</h3>
        <div class="inline" style="margin-top:8px">
          <div style="min-width:160px">
            <label for="export_limit">Last N rows</label>
            <input id="export_limit" type="number" min="1" max="10000" step="1" value="200"/>
          </div>
          <label class="inline" style="gap:6px;margin-top:24px">
            <input id="export_sanitized" type="checkbox" checked/> Sanitize internal fields
          </label>
          <label class="inline" style="gap:6px;margin-top:24px">
            <input id="export_ts" type="checkbox"/> Include timestamps
          </label>
        </div>

        <div style="margin-top:10px">
          <button id="downloadBtn">Download JSON (Beverage)</button>
        </div>
        <div id="toastExport" class="toast"></div>
        <div class="muted" style="margin-top:8px">Sanitized export removes keys starting with <code>_</code>.</div>
      </div>
    </div>
  </div>

<script>
  const el = id => document.getElementById(id);
  const api = (path, opt={}) => fetch(path, Object.assign({headers:{'Content-Type':'application/json'}}, opt));

  function showToast(where, ok, msg){
    const n = el(where);
    n.className = 'toast ' + (ok ? 'ok' : 'err');
    n.textContent = msg;
    setTimeout(()=>{ n.textContent=''; n.className='toast'; }, 3500);
  }

  function renderScenarioGrid(containerId, scen){
    const container = el(containerId);
    container.innerHTML = '';
    Object.entries(scen).forEach(([k,v])=>{
      const idr = `${containerId}_r_${k}`;
      const idn = `${containerId}_n_${k}`;
      const wrap = document.createElement('div');
      wrap.innerHTML = `
        <label>${k}</label>
        <input type="range" min="0" max="1" step="0.01" value="${v}" id="${idr}">
        <input type="number" min="0" max="1" step="0.01" value="${v}" id="${idn}">
      `;
      container.appendChild(wrap);
      const r = wrap.querySelector('#'+idr);
      const n = wrap.querySelector('#'+idn);
      r.addEventListener('input', ()=>{ n.value = r.value; });
      n.addEventListener('input', ()=>{ r.value = n.value; });
    });
  }

  function collectScenarios(containerId){
    const out = {};
    el(containerId).querySelectorAll('input[type="number"]').forEach(inp=>{
      const key = inp.id.replace(`${containerId}_n_`,'');
      out[key] = Number(inp.value);
    });
    return out;
  }

  function renderRows(items){
    const rows = el('rows'); rows.innerHTML = '';
    for (const item of items){
      const r = item.record;
      if (r.domain !== 'beverage') continue;
      const issues = (r._issues||[]).join(', ') || '—';
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td><code>${item.timestamp}</code></td>
        <td><code>${r.record_id || ''}</code></td>
        <td>${(r.text_tech||'').replaceAll('<','&lt;')}</td>
        <td>${issues}</td>`;
      rows.appendChild(tr);
    }
  }

  async function loadConfig(){
    const res = await api('/config'); const cfg = await res.json();
    el('persistInfo').textContent =
      `Config file: ${cfg._persist_path || 'config.json'}${cfg._last_saved_ts ? ' · last saved ' + new Date(cfg._last_saved_ts*1000).toLocaleString() : ''}`;

    // Fill run fields
    el('interval').value = cfg.interval_seconds;
    el('batch').value = cfg.batch_size;

    // Sink
    el('send_enabled').checked = cfg.sink.send_enabled;
    el('cluedin_endpoint').value = cfg.sink.cluedin_endpoint || '';
    el('bearer_token').value = cfg.sink.bearer_token || '';
    el('send_mode').value = cfg.sink.send_mode || 'record';
    el('timeout_seconds').value = cfg.sink.timeout_seconds ?? 6.0;
    el('max_retries').value = cfg.sink.max_retries ?? 3;

    // Scenarios
    renderScenarioGrid('scenarios_beverage', cfg.scenarios_beverage || {});
  }

  async function loadStatus(){
    const res = await api('/status'); const st = await res.json();
    el('statusBox').textContent =
      `Status: ${st.running ? 'RUNNING' : 'STOPPED'} · active domain=${st.domain} · interval=${st.interval_seconds}s · batch=${st.batch_size}`;

    const chip = el('sendStatus'); const dot = chip.querySelector('.status-dot'); const txt = chip.querySelector('span:last-child');
    const errBox = el('sendErrorBox');
    const curlWrap = el('sendCurlWrap');
    const curlText = el('sendCurlText');

    if (st.last_send_ok === true){
      dot.className='status-dot ok'; txt.textContent='Send status: OK';
      errBox.className = 'errorbox'; errBox.textContent = '';
      curlWrap.className = 'curlbox'; curlText.textContent = '';
    } else if (st.last_send_ok === false){
      dot.className='status-dot err'; txt.textContent='Send status: FAILED';
      const msg = st.last_send_error || 'Unknown error';
      errBox.textContent = msg;
      errBox.className = 'errorbox show';

      if (st.last_send_curl){
        curlText.textContent = st.last_send_curl;
        curlWrap.className = 'curlbox show';
      } else {
        curlText.textContent = '';
        curlWrap.className = 'curlbox';
      }
    } else {
      dot.className='status-dot'; txt.textContent='Send status: —';
      errBox.className = 'errorbox'; errBox.textContent = '';
      curlWrap.className = 'curlbox'; curlText.textContent = '';
    }
  }

  // Actions
  el('startBtn').onclick = async()=>{ await api('/start',{method:'POST'}); loadStatus(); };
  el('stopBtn').onclick = async()=>{ await api('/stop',{method:'POST'}); loadStatus(); };
  el('generateNowBtn').onclick = async()=>{ await api('/generate-now',{method:'POST', body: JSON.stringify({})}); };
  el('saveCore').onclick = async()=>{
    try{
      const payload = {};
      const intervalVal = parseInt(el('interval').value, 10);
      if (Number.isInteger(intervalVal) && intervalVal >= 1) payload.interval_seconds = intervalVal;
      const batchVal = parseInt(el('batch').value, 10);
      if (Number.isInteger(batchVal) && batchVal >= 1 && batchVal <= 100) payload.batch_size = batchVal;
      const res = await api('/config',{method:'POST', body: JSON.stringify(payload)});
      const j = await res.json();
      if (j.ok) { showToast('toastCore', true, j.message || 'Saved.'); await loadConfig(); await loadStatus(); }
      else { showToast('toastCore', false, 'Failed to save.'); }
    }catch(e){ showToast('toastCore', false, String(e)); }
  };
  el('makeActive').onclick = async()=>{
    try{
      const res = await api('/config',{method:'POST', body: JSON.stringify({domain:'beverage'})});
      const j = await res.json();
      if (j.ok) { showToast('toastCore', true, 'Beverage domain is now active.'); await loadStatus(); }
      else { showToast('toastCore', false, 'Failed to switch domain.'); }
    }catch(e){ showToast('toastCore', false, String(e)); }
  };
  el('saveSink').onclick = async()=>{
    try{
      const sink = {
        send_enabled: el('send_enabled').checked,
        cluedin_endpoint: el('cluedin_endpoint').value || null,
        bearer_token: el('bearer_token').value || null,
        send_mode: el('send_mode').value,
        timeout_seconds: Number(el('timeout_seconds').value),
        max_retries: Number(el('max_retries').value)
      };
      const res = await api('/config',{method:'POST', body: JSON.stringify({sink})});
      const j = await res.json();
      if (j.ok) { showToast('toastSink', true, j.message || 'Saved.'); loadStatus(); }
      else { showToast('toastSink', false, 'Failed to save.'); }
    }catch(e){ showToast('toastSink', false, String(e)); }
  };
  el('saveScenarios').onclick = async()=>{
    try{
      const payload = { scenarios_beverage: collectScenarios('scenarios_beverage') };
      const res = await api('/config',{method:'POST', body: JSON.stringify(payload)});
      const j = await res.json();
      if (j.ok) { showToast('toastScenarios', true, j.message || 'Saved.'); loadStatus(); }
      else { showToast('toastScenarios', false, 'Failed to save.'); }
    }catch(e){ showToast('toastScenarios', false, String(e)); }
  };
  el('pullScenarios').onclick = async()=>{
    await loadConfig();
    showToast('toastScenarios', true, 'Reloaded from server.');
  };

  el('copyCurlBtn').onclick = async ()=>{
    const text = el('sendCurlText').textContent || '';
    if (!text.trim()){ return; }
    try{
      await navigator.clipboard.writeText(text);
      showToast('toastSink', true, 'cURL copied');
    }catch(e){
      showToast('toastSink', false, 'Copy failed');
    }
  };

  // Charts
  let badnessChart, issuesChart;
  function initCharts(){
    const ctx1 = document.getElementById('badnessLine');
    const ctx2 = document.getElementById('issuesBar');
    badnessChart = new Chart(ctx1, {
      type: 'line',
      data: { labels: [], datasets: [{ label: '% bad (recent)', data: [] }] },
      options: { responsive:true, animation:false, scales:{ y:{ min:0, max:1 } }, plugins:{legend:{display:false}} }
    });
    issuesChart = new Chart(ctx2, {
      type: 'bar',
      data: { labels: [], datasets: [{ label: 'Issue counts', data: [] }] },
      options: { responsive:true, animation:false, indexAxis:'y', plugins:{legend:{display:false}} }
    });
  }
  function updateCharts(m){
    const ts = new Date().toLocaleTimeString();
    const dl = badnessChart.data.labels;
    const dd = badnessChart.data.datasets[0].data;
    dl.push(ts); dd.push(m.pct_bad_recent);
    if (dl.length > 60) { dl.shift(); dd.shift(); }
    badnessChart.update('none');
    issuesChart.data.labels = m.top_issues_labels || [];
    issuesChart.data.datasets[0].data = m.top_issues_values || [];
    issuesChart.update('none');
  }

  async function pollLoop(){
    try{
      const [mRes, rRes] = await Promise.all([fetch('/metrics'), fetch('/recent?n=80')]);
      const m = await mRes.json();
      const recent = (await rRes.json()).filter(x => (x.record && x.record.domain === 'beverage'));
      updateCharts(m);
      renderRows(recent);
      el('streamStatus').textContent = 'Connected (polling).';
      if (recent && recent[0]) {
        const sanitized = {};
        Object.entries(recent[0].record).forEach(([k,v])=>{ if(!k.startsWith('_')) sanitized[k]=v; });
        el('lastSentBox').textContent = JSON.stringify(sanitized, null, 2);
      }
    }catch(e){
      el('streamStatus').textContent = 'Polling error; retrying…';
    }finally{
      setTimeout(pollLoop, 2000);
    }
  }

  el('downloadBtn').onclick = ()=>{
    const limit = Math.max(1, Math.min(parseInt(el('export_limit').value||'200',10), 10000));
    const san = el('export_sanitized').checked ? 'true' : 'false';
    const ts = el('export_ts').checked ? 'true' : 'false';
    const params = new URLSearchParams({ limit: String(limit), sanitized: san, with_ts: ts, domain: 'beverage' });
    const url = `/download?${params.toString()}`;
    window.location.href = url;
  };

  (async function init(){
    await loadConfig();
    await loadStatus();
    initCharts();
    pollLoop();
    setInterval(loadStatus, 5000);
  })();
</script>
</body>
</html>
